{
  "expo": {
    "name": "Kisaan Mitra",
    "slug": "kisaan-mitra",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E20"
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "notification": {
      "color": "#1B5E20",
      "androidMode": "default",
      "androidCollapsedTitle": "Kisaan Mitra Alert"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kisaanmitra.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to find your nearest mandi."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1B5E20"
      },
      "package": "com.kisaanmitra.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "NOTIFICATIONS"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "95e557ad-d24e-41a0-b535-5ceb2d5631bc"
      }
    }
  }
}
